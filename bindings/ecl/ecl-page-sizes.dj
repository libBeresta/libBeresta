{% include "ЛИЦЕНЗИЯ.txt" %}
(in-package #:cl-beresta)
{% if размеры %}
(enum PageSizes  (
  {% for размер in размеры %}
  ;; Размер страницы "{{ размер.откуда}} {{размер.название}}" ({{размер.ширина}}мм x {{размер.высота}}мм)
  ({{ размер.ид | under }} {{ forloop.counter0 }}){% endfor %})
:prefix "PAGE-SIZE"){% endif %}
