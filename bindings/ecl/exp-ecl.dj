{% if указатели %}  ;; {{ файл }}: указатели{% for ук in указатели %}
  #:{{ ук.имя | under }}{% endfor %}{% endif %}
{% if перечисления %}
  ;;; {{ файл }}: перечисления{% for пер in перечисления %}
  ;; {{ пер.имя }}{% for эл in пер.элементы %}
  #:{{ эл.элемент | under }}{% endfor %}{% endfor %}{% endif %}{% if функции %}
  ;; {{ файл }}: функции {% for фн in функции %}
  #:{{фн.название | under}}{% endfor %}{% endif %}
